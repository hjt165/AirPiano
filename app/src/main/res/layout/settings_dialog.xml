<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1E1E1E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="设置"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp" />

        <!-- Detection Threshold -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="检测阈值 (Detection)"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/btn_detection_minus"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:backgroundTint="#44FFFFFF" />

                <TextView
                    android:id="@+id/tv_detection_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0.50"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textAlignment="center" />

                <Button
                    android:id="@+id/btn_detection_plus"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:backgroundTint="#44FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Tracking Threshold -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="跟踪阈值 (Tracking)"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/btn_tracking_minus"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:backgroundTint="#44FFFFFF" />

                <TextView
                    android:id="@+id/tv_tracking_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0.50"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textAlignment="center" />

                <Button
                    android:id="@+id/btn_tracking_plus"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:backgroundTint="#44FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Press Threshold -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="按键灵敏度 (Press)"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/btn_press_minus"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="-"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:backgroundTint="#44FFFFFF" />

                <TextView
                    android:id="@+id/tv_press_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0.07"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textAlignment="center" />

                <Button
                    android:id="@+id/btn_press_plus"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="+"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:backgroundTint="#44FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- Delegate -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="推理后端 (Delegate)"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/btn_cpu"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="CPU"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:backgroundTint="#44FFFFFF" />

                <Button
                    android:id="@+id/btn_gpu"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="GPU"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#44FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <!-- NumHands -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="检测手数 (Hands)"
                android:textColor="#AAAAAA"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <Button
                    android:id="@+id/btn_hands_1"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="单手"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:backgroundTint="#44FFFFFF" />

                <Button
                    android:id="@+id/btn_hands_2"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="双手"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:layout_marginStart="8dp"
                    android:backgroundTint="#44FFFFFF" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btn_apply"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:text="应用"
            android:textColor="#000000"
            android:minHeight="0dp"
            android:backgroundTint="#00BFA5" />
    </LinearLayout>
</ScrollView>
